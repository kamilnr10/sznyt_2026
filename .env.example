# Skopiuj do pliku .env i uzupełnij (plik .env jest w .gitignore).
#
# DatoCMS: Project settings → API tokens → „Read-only API token”
# Dokumentacja Dato podaje czasem DATOCMS_READONLY_TOKEN — w Create React App
# w przeglądarce działa tylko prefiks REACT_APP_ (bez niego token = zawsze pusty).

REACT_APP_DATOCMS_READONLY_TOKEN=

# Alternatywna nazwa (ten sam token):
# REACT_APP_DATOCMS_TOKEN=

# Opcjonalnie (stara nazwa):
# REACT_APP_TOKEN=

# Kanoniczny adres strony (https + domena, bez końcowego /) — SEO: canonical, Open Graph, JSON-LD.
# Na produkcji ustaw zgodnie z prawdziwą domeną, np. https://twojadomena.pl
# REACT_APP_SITE_URL=

# Opcjonalny pełny URL strony z polityką prywatności (baner cookies). Jeśli puste — używane jest REACT_APP_SITE_URL + /polityka-prywatnosci
# REACT_APP_PRIVACY_POLICY_URL=
